## Development image for Laravel Octane (FrankenPHP) + cloudflared.
## Build the reusable base once:
##   docker buildx build --target php-base -f Dockerfile.dev -t quantyra/idx-api-dev-base:php85 --platform linux/arm64,linux/amd64 .
## Build app image from that base:
##   docker buildx build -f Dockerfile.dev -t quantyra/idx-api-dev:latest --platform linux/arm64 .

ARG BASE_IMAGE=dunglas/frankenphp:php8.5-alpine

FROM ${BASE_IMAGE} AS php-base

ARG TARGETARCH
ENV COMPOSER_ALLOW_SUPERUSER=1

RUN apk add --no-cache \
    bash \
    curl \
    git \
    unzip \
    zip

RUN install-php-extensions \
    pcntl \
    bcmath \
    pdo_pgsql \
    pgsql \
    gd \
    zip \
    opcache \
    xdebug \
    && { \
        echo "xdebug.mode=develop,debug"; \
        echo "xdebug.start_with_request=trigger"; \
        echo "xdebug.client_host=host.docker.internal"; \
        echo "xdebug.client_port=9003"; \
        echo "xdebug.discover_client_host=0"; \
        echo "xdebug.idekey=VSCODE"; \
        echo "xdebug.log_level=0"; \
    } > /usr/local/etc/php/conf.d/99-xdebug.ini

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

RUN case "${TARGETARCH}" in \
        amd64) CLOUDFLARED_ARCH="amd64" ;; \
        arm64) CLOUDFLARED_ARCH="arm64" ;; \
        *) echo "Unsupported TARGETARCH: ${TARGETARCH}" && exit 1 ;; \
    esac \
    && curl -L "https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-${CLOUDFLARED_ARCH}" \
        -o /usr/local/bin/cloudflared \
    && chmod +x /usr/local/bin/cloudflared

WORKDIR /var/www/html

FROM php-base AS dev

ENV APP_ENV=local \
    APP_DEBUG=true \
    LOG_CHANNEL=stderr \
    CACHE_STORE=database \
    SESSION_DRIVER=database \
    QUEUE_CONNECTION=database \
    OCTANE_SERVER=frankenphp \
    OCTANE_HOST=0.0.0.0 \
    OCTANE_PORT=8000 \
    OCTANE_WATCH=true

COPY composer.json composer.lock ./
RUN composer install --no-interaction --prefer-dist --no-scripts

COPY . .
RUN composer install --no-interaction --prefer-dist

RUN mkdir -p storage/logs storage/framework/cache storage/framework/sessions storage/framework/views bootstrap/cache \
    config \
    data \
    && chown -R www-data:www-data /var/www/html

EXPOSE 8000

USER www-data

CMD ["/bin/sh", "-lc", "php artisan octane:start --server=${OCTANE_SERVER} --host=${OCTANE_HOST} --port=${OCTANE_PORT} $( [ \"${OCTANE_WATCH}\" = \"true\" ] && echo '--watch' )"]

FROM dev AS dev-worker
CMD ["/bin/sh", "-lc", "php artisan queue:work --queue=${WORKER_QUEUES:-default} --sleep=1 --tries=3 --timeout=120"]

FROM dev AS dev-scheduler
CMD ["/bin/sh", "-lc", "php artisan schedule:work"]
