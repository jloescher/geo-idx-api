# Quantyra IDX API (Go) — copy to .env for local development.
# See README.md, AGENTS.md, and docs/INDEX.md.

APP_NAME="Quantyra IDX API"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
# HTTP port for cmd/api (default 8000)
# APP_PORT=8000

# PostgreSQL (required)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=idx_api
DB_USERNAME=postgres
DB_PASSWORD=
# DB_SSLMODE=require

# Phase 2 — Patroni read replicas (API only; leave unset for local primary-only dev)
# DB_RW_DSN=postgres://user:pass@haproxy-tailscale:5000/idx_api?sslmode=require
# DB_READONLY_BASE_DSN=user=idx_reader password=secret dbname=idx_api port=5432 sslmode=require
# PATRONI_ENDPOINTS=100.126.103.51,100.114.117.46,100.115.75.119

# Goose migrations (same credentials as DB_*)
# GOOSE_DBSTRING="postgres://postgres:postgres@127.0.0.1:5432/idx_api?sslmode=disable"

# Queue (PostgreSQL jobs table — no Redis)
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=120
DB_QUEUE_RESERVATION_TIMEOUT=3600
MLS_SYNC_KICKOFF_QUEUE=sync-kickoff
WORKER_QUEUES=default,sync-kickoff,bridge-sync-fetch,bridge-sync-persist,spark-sync-fetch,spark-sync-persist

# Scheduler cluster leadership (deploy two schedulers only with advisory lock)
# SCHEDULER_LEADER_LOCK_ID=913374211
# SCHEDULER_STANDBY_POLL_SECONDS=15

# Public URLs
API_URL=http://127.0.0.1:8000
IMAGE_URL=http://127.0.0.1:8080
IDX_PLATFORM_URL=http://127.0.0.1:8000
IDX_API_PUBLIC_URL="${API_URL}"
IDX_IMAGES_PUBLIC_URL="${IMAGE_URL}"
IDX_PLATFORM_HOSTS=127.0.0.1,localhost
IDX_API_HOSTS=127.0.0.1,localhost

# Bootstrap admin (`make seed-admin`)
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_NAME=Quantyra Admin
# IDX_INVITATION_TTL_HOURS=168

# Bridge Data Output (Stellar)
BRIDGE_API_KEY=
BRIDGE_HOST=https://api.bridgedataoutput.com
BRIDGE_DATASET=stellar
BRIDGE_PATH_PREFIX=api/v2
BRIDGE_RESO_ROOT=reso/odata
BRIDGE_LISTING_PHOTO_PATH=/api/v2/{dataset}/listings/{listingKey}/photos/{photoId}
BRIDGE_TIMEOUT=30
BRIDGE_DATASETS=stellar
LISTINGS_CACHE_TTL=900
MLS_PROXY_CACHE_RETENTION_DAYS=30
MLS_LOOKUP_CACHE_TTL=2592000
BRIDGE_SYNC_FETCH_QUEUE=bridge-sync-fetch
BRIDGE_SYNC_PERSIST_QUEUE=bridge-sync-persist
BRIDGE_SYNC_PERSIST_JOB_CHUNK=75
BRIDGE_SYNC_UPSERT_CHUNK=375
BRIDGE_SYNC_MAX_REQUESTS_PER_SECOND=2
BRIDGE_SYNC_MAX_HTTP_RETRIES=4
BRIDGE_SYNC_INCLUDE_MEDIA=true
BRIDGE_SYNC_FULL_PROPERTY=true

# Spark Platform (Beaches MLS) — docs/spark/README.md
SPARK_ACCESS_TOKEN=
SPARK_DATASETS=beaches
# Large $expand replication pages need 90–120s in production
SPARK_TIMEOUT=90
SPARK_SYNC_MAX_REQUESTS_PER_SECOND=4
SPARK_SYNC_MAX_REQUESTS_PER_5MIN=1200
SPARK_SYNC_MAX_HTTP_RETRIES=4
SPARK_SYNC_FETCH_QUEUE=spark-sync-fetch
SPARK_SYNC_PERSIST_QUEUE=spark-sync-persist
SPARK_SYNC_PERSIST_JOB_CHUNK=50
SPARK_SYNC_UPSERT_CHUNK=375
# Cluster-wide queue backoff when upstream returns 429 after in-request retries
# MLS_SYNC_RATE_LIMIT_RETRY_SECONDS=300
# MLS_SYNC_TIMEOUT_RETRY_SECONDS=60
# MLS_SYNC_RATE_LIMIT_MAX_ATTEMPTS=50
# MLS_REPLICATION_RESUME_STALL_MINUTES=3
# MLS_REPLICATION_RESUME_CRON=0 */2 * * * *
# Optional smaller OData expand for Spark replication only (incremental uses MLS_SYNC_EXPAND)
# MLS_SYNC_REPLICATION_EXPAND=Media

# MLS mirror & replication (provider-agnostic)
# MLS_STELLAR_PERSIST_CHUNK_SIZE=75
# MLS_BEACHES_PERSIST_CHUNK_SIZE=50
# Wall clock per bridge.persist_chunk / spark.persist_chunk before fail+retry (default 900)
# MLS_PERSIST_CHUNK_TIMEOUT_SECONDS=900
# Rolling mirror retention (months). Purge deletes Active/Pending when COALESCE(mirror_persisted_at, modification_timestamp) is older than the window — not MLS mod time alone. Bridge /replication cannot OData-filter by timestamp; Spark replication seed still uses ModificationTimestamp gt when > 0.
# MLS_LOCAL_MIRROR_ROLLING_MONTHS=12
# MLS_REPLICA_PAGE_RETENTION_HOURS=24
# MLS_REPLICA_PAGE_FAILED_RETENTION_DAYS=7
# MLS_REPLICATION_FRESHNESS_MINUTES=15
MLS_LISTINGS_CACHE_RETENTION_DAYS=365

# GIS parcel proxy
# GIS_EDGE_CACHE_TTL=900
# GIS_ORIGIN_MAX_DAYS_PRIMARY=90
# GIS_ORIGIN_MAX_DAYS_COUNTY=30
# GIS_MAX_BBOX_SPAN_DEG=0.35
# GIS_MAX_FEATURES=500
GIS_SYNC_PAGE_SIZE=500
# GIS_SYNC_UPSERT_CHUNK=500
GIS_HTTP_TIMEOUT=120s
# GIS_SYNC_PINELLAS_ENTERPRISE=false
# GIS_SYNC_QUEUE=default
# GIS_QUEUE=default
# Dashboard boundary tiles (cities, counties, zips) show stale only after this many days without sync (default 90; quarterly SLA). Does not change sync cron.
# GIS_BOUNDARY_STALE_DAYS=90
# Teaser tier for idx:access-only PATs (idx:full and domain auth get full payloads)
GIS_TEASER_MAX_FEATURES=40
GIS_TEASER_COORD_DECIMALS=4

# FEMA NFHL flood enrichment (listings mirror; Layer 28 point queries)
# FEMA_NFHL_BASE_URL=https://hazards.fema.gov/arcgis/rest/services/public/NFHL/MapServer
# FEMA_NFHL_LAYER_ID=28
# FEMA_FLOOD_ENRICH_BATCH_SIZE=2000
# FEMA_FLOOD_STALE_DAYS=30
# FEMA_MAX_REQUESTS_PER_SECOND=8
# FEMA_HTTP_TIMEOUT=15s
# FEMA_ENRICH_QUEUE=default

# Comps closed listing cache (listings_cache; 30-day TTL, per domain+feed)
# COMPS_CLOSED_CACHE_DAYS=30
# COMPS_CLOSED_CACHE_MIN_HITS=3

# Comps home_value + listings mirror geocode backfill (Google Geocoding API, not Places)
# GOOGLE_MAPS_GEOCODING_API_KEY=
# GEOCODING_TIMEOUT=12s
# GEOCODE_QUEUE=default
# GEOCODE_BATCH_SIZE=200
# GEOCODE_MAX_REQUESTS_PER_SECOND=5

# Image filesystem cache (Docker: /var/cache/geoidx/images)
# IMAGE_CACHE_PATH=
# IMAGE_CACHE_TTL=86400

# CoinGecko pricing refresh
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_ASSET_IDS=btc,eth,sol,xrp,ada
COINGECKO_VS_CURRENCIES=usd,cad,eur,gbp,mxn
COINGECKO_CACHE_TTL_SECONDS=1200
COINGECKO_QUEUE=default

# Cloudflare tunnel (optional local HTTPS)
# CLOUDFLARED_TOKEN=
