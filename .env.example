# Quantyra IDX API (Go) — copy to .env for local development.
# See README.md, AGENTS.md, and docs/INDEX.md.

APP_NAME="Quantyra IDX API"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
# HTTP port for cmd/api (default 8000)
# APP_PORT=8000

# PostgreSQL (required)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=idx_api
DB_USERNAME=postgres
DB_PASSWORD=
# DB_SSLMODE=require

# Goose migrations (same credentials as DB_*)
# GOOSE_DBSTRING="postgres://postgres:postgres@127.0.0.1:5432/idx_api?sslmode=disable"

# Queue (PostgreSQL jobs table — no Redis)
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=120
WORKER_QUEUES=default,bridge-sync-fetch,bridge-sync-persist,spark-sync-fetch,spark-sync-persist

# Public URLs
API_URL=http://127.0.0.1:8000
IMAGE_URL=http://127.0.0.1:8080
IDX_PLATFORM_URL=http://127.0.0.1:8000
IDX_API_PUBLIC_URL="${API_URL}"
IDX_IMAGES_PUBLIC_URL="${IMAGE_URL}"
IDX_PLATFORM_HOSTS=127.0.0.1,localhost
IDX_API_HOSTS=127.0.0.1,localhost

# Bootstrap admin (`make seed-admin`)
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_NAME=Quantyra Admin
# IDX_INVITATION_TTL_HOURS=168

# Bridge Data Output (Stellar)
BRIDGE_API_KEY=
BRIDGE_HOST=https://api.bridgedataoutput.com
BRIDGE_DATASET=stellar
BRIDGE_PATH_PREFIX=api/v2
BRIDGE_RESO_ROOT=reso/odata
BRIDGE_LISTING_PHOTO_PATH=/api/v2/{dataset}/listings/{listingKey}/photos/{photoId}
BRIDGE_TIMEOUT=30
BRIDGE_DATASETS=stellar
LISTINGS_CACHE_TTL=900
MLS_PROXY_CACHE_RETENTION_DAYS=30
MLS_LOOKUP_CACHE_TTL=2592000
BRIDGE_SYNC_FETCH_QUEUE=bridge-sync-fetch
BRIDGE_SYNC_PERSIST_QUEUE=bridge-sync-persist
BRIDGE_SYNC_PERSIST_JOB_CHUNK=50
BRIDGE_SYNC_INCLUDE_MEDIA=true
BRIDGE_SYNC_FULL_PROPERTY=true

# Spark Platform (Beaches MLS) — docs/spark/README.md
SPARK_ACCESS_TOKEN=
SPARK_DATASETS=beaches
SPARK_TIMEOUT=30
SPARK_SYNC_FETCH_QUEUE=spark-sync-fetch
SPARK_SYNC_PERSIST_QUEUE=spark-sync-persist

# MLS mirror & replication (provider-agnostic)
# MLS_LOCAL_MIRROR_ROLLING_MONTHS=12
# MLS_REPLICA_PAGE_RETENTION_HOURS=24
# MLS_REPLICA_PAGE_FAILED_RETENTION_DAYS=7
# MLS_REPLICATION_FRESHNESS_MINUTES=15
MLS_LISTINGS_CACHE_RETENTION_DAYS=365

# GIS parcel proxy
# GIS_EDGE_CACHE_TTL=900
# GIS_ORIGIN_MAX_DAYS_PRIMARY=90
# GIS_ORIGIN_MAX_DAYS_COUNTY=30
# GIS_MAX_BBOX_SPAN_DEG=0.35
# Teaser tier for idx:access-only PATs (idx:full and domain auth get full payloads)
GIS_TEASER_MAX_FEATURES=40
GIS_TEASER_COORD_DECIMALS=4

# Comps home_value address geocoding
# GOOGLE_MAPS_GEOCODING_API_KEY=

# Image filesystem cache (Docker: /var/cache/geoidx/images)
# IMAGE_CACHE_PATH=
# IMAGE_CACHE_TTL=86400

# CoinGecko pricing refresh
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_ASSET_IDS=btc,eth,sol,xrp,ada
COINGECKO_VS_CURRENCIES=usd,cad,eur,gbp,mxn
COINGECKO_CACHE_TTL_SECONDS=1200
COINGECKO_QUEUE=default

# Cloudflare tunnel (optional local HTTPS)
# CLOUDFLARED_TOKEN=
