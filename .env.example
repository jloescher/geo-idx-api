APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

HASHING_DRIVER=argon2id
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=idx_api
DB_USERNAME=postgres
DB_PASSWORD=
# DB_URL=pgsql://postgres@127.0.0.1:5432/idx_api
#
# PHPUnit / `php artisan test`: DB_* above is used (see tests/bootstrap.php). For PostGIS-backed tests
# use PostgreSQL. If DB_DATABASE is not `testing` or `idx_api_testing`, set the next line so the
# suite can run (many tests use RefreshDatabase — only use on a disposable or clone database).
#ALLOW_DESTRUCTIVE_TEST_DB=true

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
DB_QUEUE_CONNECTION=
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=120
QUEUE_FAILED_DRIVER=database-uuids

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Coolify Docker build (build-time only): FrankenPHP base from GHCR — see docs/coolify-deployment.md
# FRANKENPHP_BASE_IMAGE=ghcr.io/<owner>/<repo>-frankenphp:production

# Cloudflare Turnstile (guest login, invite register, forgot/reset password). Required in staging/production web app.
# CLOUDFLARE_TURNSTILE_SITE_KEY=
# CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Invite-only registration (no public /register). Optional bootstrap admin for `php artisan db:seed`.
# ADMIN_SEED_EMAIL=
# ADMIN_SEED_PASSWORD=
# ADMIN_SEED_NAME="Quantyra Admin"
# IDX_INVITATION_TTL_HOURS=168

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Cloudflare Tunnel (named tunnel token)
# Configure public hostnames in Cloudflare Zero Trust:
# - dev-idx-api.quantyralabs.cc    -> http://idx-api-dev:8000
# - dev-idx.quantyralabs.cc        -> http://idx-api-dev:8000
# - dev-idx-images.quantyralabs.cc -> http://idx-images-dev:8080
CLOUDFLARED_TOKEN=

# Development observability
DEBUGBAR_ENABLED=true
TELESCOPE_ENABLED=true
# Staging workers: use info so bridge.replication.* logs appear in Telescope (default error)
TELESCOPE_LOG_LEVEL=info
# Production-only: set true to record all Telescope entries (high volume)
TELESCOPE_RECORD_ALL=false
PULSE_ENABLED=true

# Production protection for /telescope and /pulse (HTTP Basic Auth)
MONITORING_DASHBOARD_USERNAME=
MONITORING_DASHBOARD_PASSWORD=

# Quantyra public URLs — canonical layout:
#   APP_URL     → IDX App host (dashboard/marketing)
#   API_URL     → IDX API host (endpoints + JS embed widgets)
#   IMAGE_URL   → IDX image rewrite proxy (MLS CDN)
# Backward-compatible IDX_* vars below override these when set.
API_URL=https://idx-api.quantyralabs.cc
IMAGE_URL=https://idx-images.quantyralabs.cc
IDX_PLATFORM_URL=https://idx.quantyralabs.cc
IDX_API_PUBLIC_URL="${API_URL}"
IDX_IMAGES_PUBLIC_URL="${IMAGE_URL}"
IDX_PLATFORM_HOSTS=idx.quantyralabs.cc,dev-idx.quantyralabs.cc,staging-idx.quantyralabs.cc
IDX_API_HOSTS=idx-api.quantyralabs.cc,dev-idx-api.quantyralabs.cc,staging-idx-api.quantyralabs.cc

# Nominatim geocoding (used by /agent/searches/geocode proxy). Must identify your app.
# @see https://operations.osmfoundation.org/policies/nominatim/
GEOCODING_NOMINATIM_USER_AGENT="QuantyraIDX/1.0 (+https://example.com; contact@example.com)"
# GEOCODING_NOMINATIM_URL=https://nominatim.openstreetmap.org/search
# GEOCODING_TIMEOUT=10
# GEOCODING_CACHE_TTL=120

# Agent map search geometry limits (degrees / meters)
# AGENT_SEARCH_MAX_POLYGON_BBOX_SPAN_DEG=0.85
# AGENT_SEARCH_MAX_CIRCLE_RADIUS_M=75000

# Optional external verification API for MLS membership checks (expects JSON {active: true/false})
MLS_MEMBERSHIP_VERIFY_ENDPOINT=

# Spark Platform (Beaches MLS) — see docs/spark/README.md
SPARK_ACCESS_TOKEN=
# Optional per-dataset override (defaults to SPARK_ACCESS_TOKEN via config/mls.php)
#SPARK_BEACHES_KEY=
# SPARK_API_KEY=  # legacy alias for SPARK_ACCESS_TOKEN
SPARK_API_FEED_ID=
# Replication (sync workers only) — replication keys must not call sparkapi.com
# SPARK_REPLICATION_HOST=https://replication.sparkapi.com
# SPARK_REPLICATION_RESO_ROOT=Reso/OData
# Live RESO proxy (user-facing API paths)
# SPARK_API_HOST=https://sparkapi.com
# SPARK_API_VERSION=v1
# SPARK_LIVE_RESO_ROOT=Reso/OData
# Legacy override for replication base only:
# SPARK_RESO_BASE_URL=https://replication.sparkapi.com/Reso/OData
SPARK_DATASETS=beaches
SPARK_TIMEOUT=30
# SPARK_IMAGE_REWRITE_HOSTS=cdn.photos.sparkplatform.com
# SPARK_SYNC_REPLICATION_TOP=1000
# SPARK_SYNC_INCREMENTAL_TOP=1000
# SPARK_SYNC_INCREMENTAL_POLL_MINUTES=10
# SPARK_SYNC_EXPAND=Media,Unit,Room,OpenHouse
# SPARK_SYNC_PERSIST_JOB_CHUNK=50
# SPARK_SYNC_FETCH_QUEUE=spark-sync-fetch
# SPARK_SYNC_PERSIST_QUEUE=spark-sync-persist
# Coolify worker-fetch only:
# WORKER_QUEUES=default,bridge-sync-fetch,spark-sync-fetch
# Coolify worker-persist only:
# WORKER_QUEUES=bridge-sync-persist,spark-sync-persist

# Bridge Data Output (Stellar MLS) — see docs/bridge-api-documentation.md (read-only in repo)
BRIDGE_API_KEY=
# Optional per-dataset override (defaults to BRIDGE_API_KEY via config/mls.php)
#BRIDGE_STELLAR_KEY=
# Optional: reserved for vendors requiring a secondary secret (Basic/signed flows). Primary auth is Bearer BRIDGE_API_KEY.
BRIDGE_API_SECRET=
BRIDGE_HOST=https://api.bridgedataoutput.com
BRIDGE_DATASET=stellar
# Common: api/v2 + reso/odata (Dokploy defaults). For doc-style https://bridgedataoutput.com/stellar/... set both to empty.
BRIDGE_PATH_PREFIX=api/v2
BRIDGE_RESO_ROOT=reso/odata
BRIDGE_LISTING_PHOTO_PATH=/api/v2/{dataset}/listings/{listingKey}/photos/{photoId}
# Optional comma-separated extra hostnames to rewrite in JSON (beyond bridge host + bridgedataoutput.com)
BRIDGE_IMAGE_REWRITE_HOSTS=
BRIDGE_TIMEOUT=30
LISTINGS_CACHE_TTL=900
# Comma-separated Bridge datasets (each becomes internal catalog key bridge_{slug})
BRIDGE_DATASETS=stellar
#BRIDGE_LOOKUPS_CACHE_TTL=2592000
#IMAGE_CACHE_TTL=86400
#IMAGE_CACHE_PATH=
# Required on fetch + persist + scheduler + web (same values everywhere):
BRIDGE_SYNC_FETCH_QUEUE=bridge-sync-fetch
BRIDGE_SYNC_PERSIST_QUEUE=bridge-sync-persist
# Do NOT set BRIDGE_SYNC_QUEUE=bridge-sync (legacy monolithic name; workers will not drain it).
#BRIDGE_SYNC_REPLICATION_TOP=2000
#BRIDGE_SYNC_INCREMENTAL_TOP=200
#BRIDGE_SYNC_MAX_CHAINED_FETCH_PAGES=0
#BRIDGE_SYNC_MAX_REQUESTS_PER_SECOND=2
#BRIDGE_SYNC_MAX_REQUESTS_PER_MINUTE=120
#BRIDGE_SYNC_MAX_REQUESTS_PER_HOUR=4800
#BRIDGE_SYNC_MIN_FETCH_INTERVAL_MS=500
#BRIDGE_REPLICA_PAGE_RETENTION_HOURS=24
#BRIDGE_REPLICA_FAILED_RETENTION_DAYS=7
# Include Bridge Media[] on replica sync (stored in listings.raw_data). Required for photo references in DB.
# Increases fetch/persist payload size — use a smaller persist chunk if workers OOM (e.g. 25–50).
BRIDGE_SYNC_INCLUDE_MEDIA=true
#BRIDGE_SYNC_MAX_HTTP_RETRIES=4
#BRIDGE_LOCAL_MIRROR_ROLLING_MONTHS=12
#BRIDGE_SYNC_UPSERT_CHUNK=250
BRIDGE_SYNC_PERSIST_JOB_CHUNK=50
# Post-deploy once after upgrading from BRIDGE_SYNC_QUEUE=bridge-sync:
# php artisan bridge:migrate-legacy-queue-jobs

# MLS replication scheduling (see config/mls.php)
#MLS_REPLICATION_FRESHNESS_MINUTES=15
#MLS_CATCH_UP_KICKOFF_MINUTES=1
#MLS_STEADY_INCREMENTAL_POLL_MINUTES=15
#MLS_REPLICA_PAGE_RETENTION_HOURS=24
#MLS_REPLICA_PAGE_FAILED_RETENTION_DAYS=7
#OCTANE_SERVER=frankenphp

# MLS listings cache (see config/mls.php)
MLS_LISTINGS_CACHE_RETENTION_DAYS=365
#MLS_LISTINGS_SYNC_PAGE_SIZE=200
#MLS_LISTINGS_SYNC_MAX_PAGES=500
#MLS_LISTINGS_SYNC_MAX_ROWS=100000

# CoinGecko pricing refresh (used for listing pricing enrichment)
COINGECKO_API_KEY=
# COINGECKO_API_KEY_HEADER=x-cg-pro-api-key
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
# Internal keys (btc, eth, …) mapped to CoinGecko ids in config/coingecko.php
COINGECKO_ASSET_IDS=btc,eth,sol,xrp,ada
COINGECKO_VS_CURRENCIES=usd,cad,eur,gbp,mxn
COINGECKO_CACHE_KEY=coingecko.pricing.matrix
COINGECKO_CACHE_TTL_SECONDS=1200
COINGECKO_QUEUE=default
COINGECKO_HTTP_TIMEOUT=12
COINGECKO_HTTP_CONNECT_TIMEOUT=3

# GIS proxy (public Florida layers): edge Laravel cache TTL (seconds), origin max-age (days), metadata probe timeouts
#GIS_EDGE_CACHE_TTL=900
#GIS_ORIGIN_MAX_DAYS_PRIMARY=90
#GIS_ORIGIN_MAX_DAYS_COUNTY=30
#GIS_ORIGIN_MAX_AGE_DAYS_DEFAULT=30
#GIS_METADATA_TIMEOUT=12
#GIS_METADATA_CONNECT_TIMEOUT=3

# Sanctum server-to-server token for geo-web (also seeded once via GeoWebInternalTokenSeeder)
IDX_API_INTERNAL_TOKEN=

# Prevent dangerous schema wipe commands when connected to protected/shared DBs.
# Required for `migrate:fresh` / `migrate:reset` / `db:wipe` when DB_DATABASE matches a
# protected name fragment (default: prod, production, staging — e.g. *staging* databases).
# Unrelated to PHPUnit's ALLOW_DESTRUCTIVE_TEST_DB. Set true only for intentional maintenance, then revert.
#ALLOW_DESTRUCTIVE_DB_COMMANDS=false
#PROTECTED_DATABASE_NAME_FRAGMENTS=prod,production,staging
# If you use `php artisan config:cache`, run `php artisan config:clear` after changing the above so `config/debug_audit.php` is re-read.

# Emergency only: allow Eloquent user delete/forceDelete when APP_ENV=production
#ALLOW_USER_DELETION_IN_PRODUCTION=false
