{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".cursor/hooks/skill-instructions-hook.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SUMMONAIKIT_HOOK_PHASE=verify .cursor/hooks/skill-instructions-hook.sh"
          }
        ]
      }
    ]
  }
}
