{
  "cases": [
    {
      "name": "gis_bbox",
      "method": "GET",
      "path": "/api/v1/gis",
      "query": { "bbox": "{{bbox}}" },
      "expect_status": [200, 400],
      "expect_status_unauthed": [401],
      "expect_json_when_status": [200],
      "expect_json": {
        "type": "string",
        "features": "array"
      },
      "expect_json_equals": { "type": "FeatureCollection" },
      "export_as": "gis-bbox-parcels.json",
      "nextjs_hint": "Fetch GeoJSON FeatureCollection with ?bbox=west,south,east,north."
    },
    {
      "name": "mls_gis_bbox",
      "method": "GET",
      "path": "/api/v1/mls/{{dataset}}/gis",
      "query": { "bbox": "{{bbox}}" },
      "expect_status": [200, 400],
      "expect_status_unauthed": [401],
      "expect_json_when_status": [200],
      "expect_json": {
        "type": "string",
        "features": "array"
      }
    },
    {
      "name": "autocomplete_cities",
      "method": "GET",
      "path": "/api/v1/gis/autocomplete/cities",
      "query": { "q": "tam", "limit": "5" },
      "expect_status": [200],
      "expect_status_unauthed": [401],
      "expect_json_array": true,
      "export_as": "gis-autocomplete-cities.json"
    },
    {
      "name": "autocomplete_counties",
      "method": "GET",
      "path": "/api/v1/gis/autocomplete/counties",
      "query": { "q": "pin", "limit": "5" },
      "expect_status": [200],
      "expect_status_unauthed": [401],
      "expect_json_array": true,
      "export_as": "gis-autocomplete-counties.json"
    }
  ]
}
