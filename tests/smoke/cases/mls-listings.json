{
  "cases": [
    {
      "name": "listings_collection",
      "method": "GET",
      "path": "/api/v1/listings",
      "query": { "dataset": "{{dataset}}", "limit": "2" },
      "expect_status": [200],
      "expect_status_unauthed": [401],
      "expect_json": { "bundle": "array", "total": "number" },
      "export_as": "listings-collection.json",
      "nextjs_hint": "GET listings with ?dataset=stellar&limit=2 and Bearer + X-Domain-Slug headers."
    },
    {
      "name": "listing_by_id",
      "method": "GET",
      "path": "/api/v1/listings/{{mls_listing_id}}",
      "query": { "dataset": "{{dataset}}" },
      "expect_status": [200],
      "expect_status_unauthed": [401]
    },
    {
      "name": "properties_collection",
      "method": "GET",
      "path": "/api/v1/properties",
      "query": { "dataset": "{{dataset}}", "$top": "2" },
      "expect_status": [200],
      "expect_status_unauthed": [401],
      "expect_json": { "value": "array" }
    },
    {
      "name": "properties_post",
      "method": "POST",
      "path": "/api/v1/properties",
      "query": { "dataset": "{{dataset}}" },
      "headers": { "Content-Type": "application/json" },
      "body": { "city": "Largo", "limit": 2 },
      "expect_status": [200, 403],
      "expect_status_unauthed": [401],
      "warn_on_status": [403],
      "export_as": "properties-post-search.json",
      "nextjs_hint": "POST body convenience is translated to OData $filter/$top. 403 is Cloudflare caching distribution (only cacheable methods allowed to this path); handler itself works when reached."
    },
    {
      "name": "properties_convenience_get",
      "method": "GET",
      "path": "/api/v1/properties",
      "query": { "dataset": "{{dataset}}", "city": "Largo", "limit": "2" },
      "expect_status": [200],
      "expect_status_unauthed": [401],
      "expect_json": { "value": "array" },
      "export_as": "properties-get-search.json"
    },
    {
      "name": "property_by_key",
      "method": "GET",
      "path": "/api/v1/properties/{{listing_key}}",
      "query": { "dataset": "{{dataset}}", "$select": "ListingKey,City" },
      "expect_status": [200],
      "expect_status_unauthed": [401]
    },
