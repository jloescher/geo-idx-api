# Copy to .env.backfill.local (gitignored) and set your DSN(s).
#
# Long backfills: prefer Patroni primary on :5432 over HAProxy :5000 (idle timeout ~60–120s).
# export BACKFILL_DSN='postgres://USER:PASS@<patroni-tailscale-host>:5432/geoidxapi?sslmode=require'
# export GOOSE_DBSTRING='postgres://USER:PASS@100.x.x.x:5000/geoidxapi?sslmode=require'  # HAProxy (short queries OK)
#
export GOOSE_DBSTRING='postgres://USER:PASS@HOST:5432/geoidxapi?sslmode=require&keepalives=1&keepalives_idle=20&keepalives_interval=5&keepalives_count=5'
#
# Runner tuning (optional):
# SKIP_INSTALL=1
# BACKFILL_BATCH_TIMEOUT_SEC=120   # listings backfill psql timeout
# BACKFILL_BATCH_PAUSE_SEC=2       # pause between successful batches on :5000 (default 2)
# BACKFILL_MAX_CONSECUTIVE_FAILURES=25
#
# GIS cities/county expand (docs/scripts/run_gis_cities_county_expand.sh):
#   ./docs/scripts/run_gis_cities_county_expand.sh check
#   ./docs/scripts/run_gis_cities_county_expand.sh 5 reconnect
# GIS_BATCH_TIMEOUT_SEC=300        # spatial joins per batch (default 300)
# GIS_COMMIT_EVERY=5               # monolithic mode only
