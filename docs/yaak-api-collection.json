{
  "openapi": "3.1.0",
  "info": {
    "title": "Quantyra GeoIDX API",
    "description": "OpenAPI document for the **idx-api** host: Sanctum auth, versioned Bridge MLS proxy (`/api/v1/*`), GIS parcel GeoJSON, structured search, comps engine, PostGIS replication stats, and authenticated listing photo streaming (`/api/images/*`). Routes are registered from `routes/api.php` and `bootstrap/app.php` (image proxy).",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://dev-idx-api.quantyralabs.cc",
      "description": "Development API host (replace with your `APP_URL` / `IDX_API_PUBLIC_URL`)"
    },
    {
      "url": "http://localhost:8000",
      "description": "Local `php artisan serve` (default port)"
    }
  ],
  "tags": [
    { "name": "Authentication", "description": "`POST /api/auth/token` and `GET /api/auth/user` (Sanctum)." },
    { "name": "MLS Data - Listings", "description": "Bridge-backed Property and listing resources (`domain.token` + `mls.access`)." },
    { "name": "MLS Data - Agents & Offices", "description": "Agents, offices, and RESO office resources." },
    { "name": "MLS Data - Open Houses", "description": "Open house collections and RESO open house resources." },
    { "name": "MLS Data - Members & Lookup", "description": "Members and lookup helpers." },
    { "name": "MLS Data - Public Records", "description": "Public parcels, assessments, and transactions under `/api/v1/pub/*`." },
    { "name": "MLS Data - Search", "description": "`POST /api/v1/search` structured RESO search with caching." },
    { "name": "Comps Engine", "description": "`POST /api/v1/comps/run` comparables, investor modes, BPO, and home value." },
    { "name": "GIS Parcel Proxy", "description": "`GET /api/v1/gis` and MLS-scoped GIS routes." },
    { "name": "Operations", "description": "Replication / mirror statistics for operators." },
    { "name": "Images", "description": "Streaming Bridge listing photos through the API (same auth as Bridge JSON)." }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token for Sanctum `PersonalAccessToken` routes guarded by `domain.token` (`/api/v1/*`, `/api/images/*`). Typical abilities: **`idx:full`** (dashboard PATs, `POST /api/auth/token`) or **`idx:access`** (some tokens / domain flows). `idx:access` applies teaser caps on list-shaped MLS JSON; `idx:full` does not. Pair calls with `X-Domain-Slug` or `?domain=` when your token is not domain-scoped by referer."
      }
    },
    "schemas": {
      "AuthRequest": {
        "type": "object",
        "required": ["email", "password", "device_name"],
        "properties": {
          "email": { "type": "string", "format": "email", "example": "test@example.com" },
          "password": { "type": "string", "example": "password" },
          "device_name": { "type": "string", "example": "yaak-testing" }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string", "example": "1|xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "email_verified_at": { "type": "string", "nullable": true },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string" }
        }
      },
      "ListingsResponse": {
        "type": "object",
        "properties": {
          "pricing": {
            "type": "object",
            "description": "Global quote matrix used for listing-level conversion output.",
            "properties": {
              "status": { "type": "string", "example": "ok" },
              "as_of": { "type": "string", "format": "date-time", "nullable": true },
              "quotes": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "number"
                  }
                }
              }
            }
          },
          "value": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ListPrice": { "type": "number", "nullable": true },
                "pricing_converted": {
                  "type": "object",
                  "properties": {
                    "base_currency": { "type": "string", "example": "usd" },
                    "fiat": {
                      "type": "object",
                      "additionalProperties": { "type": "number" }
                    },
                    "digital_assets": {
                      "type": "object",
                      "additionalProperties": { "type": "number" }
                    }
                  }
                }
              },
              "additionalProperties": true
            }
          },
          "links": { "type": "object" },
          "meta": { "type": "object" }
        }
      },
      "GisResponse": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "example": "FeatureCollection" },
          "features": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/api/auth/token": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Login - Get API Token",
        "description": "Authenticate and obtain a Sanctum bearer token (`idx:full`). Use the returned token in the Authorization header together with `X-Domain-Slug` or `?domain=` for `/api/v1/*` calls.\n\n**Test credentials (local / seeded):**\n- Email: test@example.com\n- Password: password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token generated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponse" }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/auth/user": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Get Current User",
        "description": "Returns the authenticated user's details.",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Authenticated user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "401": {
            "description": "Unauthenticated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/listings": {
      "get": {
        "tags": ["MLS Data - Listings"],
        "summary": "Get Listings",
        "description": "Get MLS listings for the resolved MLS feed (Bridge web collection when `filters` is set; merged Active/Pending Bridge RESO slice when `filters` is absent). Responses include top-level `pricing` and per-row `pricing_converted` when `ListPrice` is present. **Collection cache:** 15-minute TTL applies per domain when **`filters` is absent**; any `filters` query parameter bypasses the cache and forwards to Bridge. Standard Bridge query parameters are passed through.",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Listings retrieved successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListingsResponse" }
              }
            }
          },
          "401": { "description": "Unauthenticated" },
          "403": { "description": "Forbidden" }
        }
      }
    },
    "/api/v1/listings/{listingId}": {
      "get": {
        "tags": ["MLS Data - Listings"],
        "summary": "Get Listing by ID",
        "description": "Get a specific MLS listing by its ID. Listing payload includes pricing enrichment fields when `ListPrice` is available.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "listingId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The listing identifier"
          }
        ],
        "responses": {
          "200": { "description": "Listing details" },
          "401": { "description": "Unauthenticated" },
          "404": { "description": "Listing not found" }
        }
      }
    },
    "/api/v1/properties": {
      "get": {
        "tags": ["MLS Data - Listings"],
        "summary": "Search Properties",
        "description": "Search properties with query parameters. For structured payloads, use POST /api/v1/properties.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "city",
            "in": "query",
            "schema": { "type": "string" },
            "example": "Orlando"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 10 }
          }
        ],
        "responses": {
          "200": { "description": "Search results" },
          "401": { "description": "Unauthenticated" }
        }
      },
      "post": {
        "tags": ["MLS Data - Listings"],
        "summary": "Search Properties (JSON body)",
        "description": "Compatibility endpoint that accepts JSON body and translates convenience fields to RESO OData. Currently supports `city` and `limit`.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "city": { "type": "string", "example": "Largo" },
                  "limit": { "type": "integer", "minimum": 1, "maximum": 200, "example": 10 }
                }
              },
              "examples": {
                "single_city": {
                  "summary": "Single city search",
                  "value": {
                    "city": "Largo",
                    "limit": 10
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Search results" },
          "400": { "description": "Invalid request parameters" },
          "401": { "description": "Unauthenticated" }
        }
      }
    },
    "/api/v1/properties/{listingKey}": {
      "get": {
        "tags": ["MLS Data - Listings"],
        "summary": "Get Property by Key",
        "description": "Get a specific property by its listing key.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "listingKey",
