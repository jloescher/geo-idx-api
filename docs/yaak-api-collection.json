    "/api/v1/comps/run": {
      "post": {
        "tags": ["Comps Engine"],
        "summary": "Run comparables, investor analysis, BPO, or home value",
        "description": "Bridge-backed comps endpoint. Modes **A–E** are sales-comp grids; **`rent_hold_cashflow`**, **`flip_vs_hold`**, **`appraiser_simulation`**, **`bpo`**, and **`home_value`** require **`idx:full`** (see `CompsRunRequest` + `BridgeCompsService`). **`home_value`** uses distinct `subject.*` and optional `home_value_params` (see validation rules in code).",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["subject", "mode", "scope"],
                "properties": {
                  "subject": {
                    "type": "object",
                    "properties": {
                      "type": { "type": "string", "enum": ["mls", "off_market"] },
                      "listing_id": { "type": "string", "example": "stellar:12345" },
                      "lat": { "type": "number", "example": 27.9506 },
                      "lng": { "type": "number", "example": -82.4572 },
                      "bedrooms": { "type": "number", "example": 3 },
                      "bathrooms": { "type": "number", "example": 2 },
                      "living_area_sqft": { "type": "integer", "example": 1850 },
                      "lot_size_sqft": { "type": "integer", "example": 8500 },
                      "garage_spaces": { "type": "integer", "example": 2 },
                      "monthly_fees": { "type": "number", "example": 250 }
                    }
                  },
                  "mode": {
                    "type": "string",
                    "enum": ["A", "B", "C", "D", "E", "rent_hold_cashflow", "flip_vs_hold", "appraiser_simulation", "bpo", "home_value"]
                  },
                  "scope": {
                    "type": "object",
                    "properties": {
                      "type": { "type": "string", "enum": ["radius", "zip"] },
                      "radius_miles": { "type": "number", "example": 5 },
                      "postal_codes": { "type": "array", "items": { "type": "string" } }
                    }
                  },
                  "filters": { "type": "object" },
                  "rental_params": { "type": "object" },
                  "flip_params": { "type": "object" },
                  "simulation_params": { "type": "object" }
                }
              },
              "examples": {
                "mode_a_mls_radius": {
                  "summary": "Mode A sales comps by radius",
                  "value": {
                    "subject": { "type": "mls", "listing_id": "stellar:12345" },
                    "mode": "A",
                    "scope": { "type": "radius", "radius_miles": 5 },
                    "filters": {
                      "sold_months_back": 12,
                      "max_sold_comps": 12,
                      "match_garage_spaces": true,
                      "min_garage_spaces": 1
                    }
                  }
                },
                "mode_b_off_market_zip": {
                  "summary": "Mode B with off-market subject and zip scope",
                  "value": {
                    "subject": {
                      "type": "off_market",
                      "lat": 27.95,
                      "lng": -82.45,
                      "bedrooms": 3,
                      "bathrooms": 2,
                      "living_area_sqft": 1700,
                      "garage_spaces": 1
                    },
                    "mode": "B",
                    "scope": { "type": "zip", "postal_codes": ["33602", "33606"] },
                    "filters": { "max_sold_comps": 10 }
                  }
                },
                "mode_c_with_competition": {
                  "summary": "Mode C including active/pending competition",
                  "value": {
                    "subject": { "type": "mls", "listing_id": "stellar:12345" },
                    "mode": "C",
                    "scope": { "type": "radius", "radius_miles": 7 },
                    "filters": {
                      "include_active_pending": true,
                      "max_competition_comps": 20,
                      "include_overpriced_signals": true
                    }
                  }
                },
                "mode_d_neutral_keyword_scores": {
                  "summary": "Mode D with neutral keyword scoring",
                  "value": {
                    "subject": { "type": "mls", "listing_id": "stellar:12345" },
                    "mode": "D",
                    "scope": { "type": "radius", "radius_miles": 6 },
                    "filters": { "max_sold_comps": 8 }
                  }
                },
                "mode_e_neutral_keyword_scores": {
                  "summary": "Mode E with neutral keyword scoring",
                  "value": {
                    "subject": { "type": "mls", "listing_id": "stellar:12345" },
                    "mode": "E",
                    "scope": { "type": "radius", "radius_miles": 6 },
                    "filters": { "max_sold_comps": 8 }
                  }
                },
                "rent_hold_cashflow": {
                  "summary": "Investor rent-hold cashflow analysis",
                  "value": {
                    "subject": { "type": "mls", "listing_id": "stellar:12345" },
                    "mode": "rent_hold_cashflow",
                    "scope": { "type": "radius", "radius_miles": 8 },
                    "rental_params": {
                      "purchase_price": 450000,
                      "down_payment_percent": 20,
                      "interest_rate": 7.0,
                      "loan_term_years": 30,
                      "annual_tax": 5200,
                      "annual_insurance": 2400,
                      "monthly_hoa": 150
                    }
                  }
                },
                "flip_vs_hold": {
                  "summary": "Investor flip vs hold analysis",
                  "value": {
                    "subject": { "type": "mls", "listing_id": "stellar:12345" },
                    "mode": "flip_vs_hold",
                    "scope": { "type": "radius", "radius_miles": 8 },
                    "rental_params": { "purchase_price": 450000, "down_payment_percent": 20 },
                    "flip_params": {
                      "purchase_price": 450000,
                      "rehab_budget": 50000,
                      "holding_months": 6,
                      "closing_costs_sell_pct": 7
                    }
                  }
                },
                "appraiser_simulation": {
                  "summary": "Appraiser simulation with BPO band and risk",
                  "value": {
                    "subject": { "type": "mls", "listing_id": "stellar:12345" },
                    "mode": "appraiser_simulation",
                    "scope": { "type": "radius", "radius_miles": 5 },
                    "simulation_params": {
                      "supporting_comp_count": 8,
                      "high_adjustment_threshold_pct": 25
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Comps run completed" },
          "401": { "description": "Unauthenticated" },
          "403": { "description": "Forbidden or `idx:full` required for premium modes (investor, BPO, home value)" },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/api/v1/search": {
      "post": {
        "tags": ["MLS Data - Search"],
        "summary": "Structured MLS Search",
        "description": "Searches Bridge RESO Property data through the proxy with request-level caching (15 minute TTL), teaser gating when the resolved token/context is not `idx:full`, and domain dataset restrictions.\n\nUse `?dataset=` to select a dataset when enabled for the domain/site.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "dataset",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "example": "stellar" },
            "description": "Optional MLS dataset override. Must be globally configured and enabled for the requesting domain/site."
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "min_price": { "type": "number", "example": 250000 },
                  "max_price": { "type": "number", "example": 600000 },
                  "min_beds": { "type": "integer", "example": 3 },
                  "max_beds": { "type": "integer", "example": 5 },
                  "city": { "type": "string", "example": "Tampa" },
                  "statuses": {
                    "type": "array",
                    "items": { "type": "string" },
                    "example": ["Active"]
                  },
                  "low_risk_floodzone": { "type": "boolean", "example": true },
                  "sort": { "type": "string", "example": "list_price" },
                  "sort_dir": { "type": "string", "example": "desc" },
                  "page": {
                    "type": "object",
                    "properties": {
                      "limit": { "type": "integer", "example": 24 },
                      "skip": { "type": "integer", "example": 0 }
                    }
                  },
                  "focus_areas": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "enum": ["city", "county", "state", "postal_code", "elementary_school", "middle_school", "high_school", "subdivision"]
                        },
                        "name": { "type": "string" }
                      },
                      "required": ["type", "name"]
                    }
                  }
                }
              },
              "examples": {
                "baseline_active": {
                  "summary": "Baseline active listings (no geo)",
                  "value": {
                    "active_only": true,
                    "statuses": ["Active"],
                    "page": { "limit": 24, "skip": 0 }
                  }
                },
                "multiple_cities": {
                  "summary": "Multiple city OR search",
                  "value": {
                    "focus_areas": [
                      { "type": "city", "name": "Largo" },
                      { "type": "city", "name": "Clearwater" },
                      { "type": "city", "name": "St. Petersburg" }
                    ],
                    "page": { "limit": 24, "skip": 0 }
                  }
                },
                "county_or_city_outside_county": {
                  "summary": "County OR city outside county",
                  "value": {
                    "focus_areas": [
                      { "type": "county", "name": "Pinellas" },
                      { "type": "city", "name": "Tampa" }
                    ],
                    "statuses": ["Active"],
                    "page": { "limit": 24, "skip": 0 }
                  }
                },
                "mixed_state_county_city": {
                  "summary": "State/county/city combined OR",
                  "value": {
                    "focus_areas": [
                      { "type": "state", "name": "FL" },
                      { "type": "county", "name": "Hillsborough" },
                      { "type": "city", "name": "Orlando" }
                    ],
                    "min_price": 250000,
                    "max_price": 750000,
                    "page": { "limit": 24, "skip": 0 }
                  }
                },
                "county_state_postal_mix": {
                  "summary": "County + state + postal code mix",
                  "value": {
                    "focus_areas": [
                      { "type": "county", "name": "Pinellas" },
                      { "type": "state", "name": "FL" },
                      { "type": "postal_code", "name": "33701" }
                    ],
                    "statuses": ["Active", "Pending"],
                    "page": { "limit": 24, "skip": 0 }
                  }
                },
                "price_beds_baths_sqft": {
                  "summary": "Price + beds/baths + square footage",
                  "value": {
                    "min_price": 300000,
                    "max_price": 900000,
                    "min_beds": 3,
                    "max_beds": 5,
                    "min_baths": 2,
                    "max_baths": 4,
                    "min_sqft": 1600,
                    "max_sqft": 4200,
                    "page": { "limit": 24, "skip": 0 }
                  }
                },
                "property_types_and_statuses": {
                  "summary": "Property types/subtypes with multiple statuses",
                  "value": {
                    "property_types": ["Residential"],
                    "property_sub_types": ["Single Family Residence", "Townhouse"],
                    "statuses": ["Active", "Pending", "Coming Soon"],
                    "page": { "limit": 24, "skip": 0 }
                  }
                },
                "boolean_features": {
                  "summary": "Boolean feature toggles",
                  "value": {
                    "waterfront": true,
                    "pool_private": true,
                    "dock": true,
                    "new_construction": true,
                    "has_photos": true,
                    "garage": true,
                    "association": true,
                    "spa": false,
                    "fireplace": true,
                    "active_adult_community": false,
                    "page": { "limit": 24, "skip": 0 }
                  }
                },
                "monthly_fees_stories_year_dom": {
                  "summary": "HOA fees + stories + year built + DOM",
                  "value": {
                    "min_monthly_fees": 100,
                    "max_monthly_fees": 700,
                    "min_stories": 1,
                    "max_stories": 2,
                    "min_year_built": 1990,
                    "max_year_built": 2025,
                    "min_days_on_market": 1,
                    "max_days_on_market": 45,
                    "page": { "limit": 24, "skip": 0 }
                  }
                },
                "flood_zone_and_price_reduction": {
                  "summary": "Flood zone + recent price reduction",
                  "value": {
                    "low_risk_floodzone": true,
                    "price_reduced_within_days": 30,
                    "statuses": ["Active"],
                    "page": { "limit": 24, "skip": 0 }
                  }
                },
                "for_lease_with_special_conditions": {
                  "summary": "For lease + special listing conditions",
                  "value": {
                    "for_lease": true,
                    "special_listing_conditions": ["Short Sale", "REO"],
                    "statuses": ["Active"],
                    "page": { "limit": 24, "skip": 0 }
                  }
                },
                "geo_distance_radius": {
                  "summary": "Distance search around a point",
                  "value": {
                    "geo": {
                      "distance": {
                        "lat": 27.9506,
                        "lng": -82.4572,
                        "radius_miles": 8
                      }
                    },
                    "sort": "distance",
                    "sort_dir": "asc",
                    "page": { "limit": 24, "skip": 0 }
                  }
                },
                "geo_bounding_box": {
                  "summary": "Bounding box search",
                  "value": {
                    "geo": {
                      "bbox": {
                        "west": -82.60,
                        "south": 27.86,
                        "east": -82.32,
                        "north": 28.05
                      }
                    },
                    "statuses": ["Active"],
                    "page": { "limit": 24, "skip": 0 }
                  }
                },
                "sorting_variants": {
                  "summary": "Sort by list price descending",
                  "value": {
                    "statuses": ["Active"],
                    "sort": "list_price",
                    "sort_dir": "desc",
                    "page": { "limit": 24, "skip": 0 }
                  }
                },
                "pagination_followup": {
                  "summary": "Second page request",
                  "value": {
                    "statuses": ["Active"],
                    "sort": "on_market_date",
                    "sort_dir": "desc",
                    "page": { "limit": 24, "skip": 24 }
                  }
                },
                "dataset_override": {
                  "summary": "Use query dataset with focused payload",
                  "description": "Send request as POST /api/v1/search?dataset=stellar",
                  "value": {
                    "focus_areas": [
                      { "type": "city", "name": "Largo" }
                    ],
                    "statuses": ["Active"],
                    "page": { "limit": 24, "skip": 0 }
                  }
                },
                "combined_real_world": {
                  "summary": "Real-world combined search",
                  "value": {
                    "focus_areas": [
                      { "type": "county", "name": "Pinellas" },
                      { "type": "city", "name": "Tampa" }
                    ],
                    "min_price": 350000,
                    "max_price": 1200000,
                    "min_beds": 3,
                    "min_baths": 2,
                    "property_types": ["Residential"],
                    "waterfront": true,
                    "has_photos": true,
                    "low_risk_floodzone": true,
                    "sort": "list_price",
                    "sort_dir": "desc",
                    "page": { "limit": 24, "skip": 0 }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Search results" },
          "400": { "description": "Invalid request or unavailable dataset" },
          "401": { "description": "Unauthenticated" },
          "403": { "description": "Dataset not enabled for site or token/domain not permitted" }
        }
      }
    },
    "/api/v1/gis": {
      "get": {
        "tags": ["GIS Parcel Proxy"],
        "summary": "Get GIS Data (General)",
        "description": "Get GIS parcel geometry data for a bounding box. Returns GeoJSON FeatureCollection.\n\n**Example bbox (Tampa Bay):** `-82.8,27.9,-82.6,28.0`",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "bbox",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Bounding box as minLon,minLat,maxLon,maxLat (max span: 0.35 degrees)"
          }
        ],
        "responses": {
          "200": {
            "description": "GeoJSON FeatureCollection",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GisResponse" }
              }
            }
          },
          "400": { "description": "Invalid bbox" }
        }
      }
    },
    "/api/v1/mls/{mlsCode}/gis": {
      "get": {
        "tags": ["GIS Parcel Proxy"],
        "summary": "Get GIS Data (MLS-scoped)",
        "description": "Get GIS parcel data scoped to a specific MLS dataset.\n\n**Default MLS dataset:** stellar",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "mlsCode",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "example": "stellar" }
          },
          {
            "name": "bbox",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Bounding box as minLon,minLat,maxLon,maxLat"
          }
        ],
        "responses": {
          "200": { "description": "GeoJSON FeatureCollection" },
          "400": { "description": "Invalid bbox" }
        }
      }
    },
    "/api/v1/bridge/stats": {
      "get": {
        "tags": ["Operations"],
        "summary": "PostGIS replication / mirror statistics",
        "description": "Per-dataset listing counts and `ListingSyncCursor` metadata for the local Bridge mirror. Same middleware as other `/api/v1/*` routes (`domain.token`, `mls.access`).",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "JSON stats payload per configured MLS dataset slug" },
          "401": { "description": "Unauthenticated" },
          "403": { "description": "Forbidden" }
        }
      }
    },
    "/api/images/{listingKey}/{photoId}": {
      "get": {
        "tags": ["Images"],
        "summary": "Stream a listing photo (Bridge origin)",
        "description": "Proxies the Bridge listing photo binary through idx-api. Registered with `domain.token` in `bootstrap/app.php` (same identity resolution as MLS JSON). Clients normally consume photos via the public image edge host; this operation documents the API path shape.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "listingKey",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" }
          },
          {
            "name": "photoId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" }
          }
        ],
        "responses": {
          "200": {
            "description": "Image bytes (upstream `Content-Type`; long-cache headers in production).",
            "content": {
              "image/jpeg": { "schema": { "type": "string", "format": "binary" } },
              "image/png": { "schema": { "type": "string", "format": "binary" } },
              "application/octet-stream": { "schema": { "type": "string", "format": "binary" } }
            }
          },
          "401": { "description": "Unauthenticated" },
          "403": { "description": "Forbidden" },
          "404": { "description": "Image not found at Bridge origin" }
        }
      }
    }
  }
}
