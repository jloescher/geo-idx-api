# Quantyra IDX-Images — build from monorepo ROOT (context: .)
# Nginx TLS edge → idx-api:8000/images/* (Laravel DomainOrTokenAuth + disk cache).

FROM nginx:1.27-alpine

COPY docker/nginx.idx-images.conf /etc/nginx/conf.d/default.conf

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD wget -q -O- http://127.0.0.1:8080/health || exit 1

CMD ["nginx", "-g", "daemon off;"]
